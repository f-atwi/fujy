[ "$_fujy_loaded" ] && return 0
_fujy_loaded=1

[ "$_hivecore_loaded" ] || {
    echo "fujy: hivecore plugin not loaded — run: fly add f-atwi/hivecore" >&2
    return 1
}

flyjssh()  { _fly_transport_run juju "$@"; }
fjssh()    { flyjssh "$@"; }
flyjsshb() { _fly_destshell=bash flyjssh "$@"; }
flyjsshz() { _fly_destshell=zsh  flyjssh "$@"; }
flyjsshk() { _fly_destshell=ksh  flyjssh "$@"; }

[ "$_fujy_juju_cwd" ] && \cd "$_fujy_juju_cwd" 2>/dev/null && unset _fujy_juju_cwd
